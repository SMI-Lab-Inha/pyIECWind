# Ship a coherent, runnable test suite and the docs source in the sdist.
recursive-include tests *.py
recursive-include tests/golden *.wnd
recursive-include docs *.rst *.py Makefile make.bat
recursive-include examples *.ipt
include CHANGELOG.md
include CITATION.cff
include MANIFEST.in
include .gitattributes

# Never ship build/scratch artifacts.
prune tests/.tmp
prune docs/_build
